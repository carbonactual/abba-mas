# OpenRouter model gateway
# Add real secret values only in Vercel/GitHub secret stores. Never commit them.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://carbonactual.com
OPENROUTER_APP_TITLE=ABBA MAS
OPENROUTER_DEFAULT_MODEL=openrouter/auto

# Optional comma-separated exact models or provider wildcards, for example:
# OPENROUTER_ALLOWED_MODELS=openrouter/auto,openai/*,anthropic/*,google/*
OPENROUTER_ALLOWED_MODELS=

# Keep false until streaming, schema validation, provider policies and SEAL gates pass review.
OPENROUTER_PRODUCTION_ENABLED=false
