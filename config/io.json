{
  "version": "1.0.0",
  "id": "io",
  "name": "I/O",
  "role": "universal-movement-coordination-and-settlement-layer",
  "doctrine": "One shared I/O system serves the ecosystem. Context, need, consent, risk and authority determine which capabilities are activated.",
  "subjects": ["hash","hapi","abba","ai-agent","product","entity","department","project","swarm","marketplace","external-partner","device"],
  "domains": {
    "wallets": {"enabled": true, "shared": true, "config": "config/wallets.json"},
    "communication": {"enabled": true, "shared": true, "config": "config/communication.json"},
    "management": {"enabled": true, "shared": true, "config": "config/management.json"},
    "trading": {"enabled": true, "shared": true, "config": "config/trading.json"},
    "payments": {"enabled": true},
    "escrow": {"enabled": true},
    "credit": {"enabled": true, "licensedPartnerRequiredWhereApplicable": true},
    "assetsLiabilities": {"enabled": true},
    "custody": {"enabled": true, "regulatedCustodyRequiresPartner": true},
    "treasuryLiquidity": {"enabled": true},
    "logistics": {"enabled": true},
    "dataDocuments": {"enabled": true},
    "energy": {"enabled": true},
    "computeAI": {"enabled": true},
    "permissionsMandates": {"enabled": true},
    "clearingSettlement": {"enabled": true},
    "reconciliationRecovery": {"enabled": true},
    "eventsPulse": {"enabled": true},
    "proof": {"enabled": true},
    "actualization": {"enabled": true}
  },
  "mandatoryControls": [
    "identity-linkage",
    "seal-policy",
    "purpose-limitation",
    "tenant-isolation",
    "idempotency",
    "double-entry-for-financial-movement",
    "immutable-audit-events",
    "proof-reference",
    "reconciliation",
    "reversal-or-compensation-path",
    "human-final-authority-for-sensitive-actions"
  ],
  "eventEnvelopeSchema": "schemas/io-event.schema.json",
  "activationManifestSchema": "schemas/io-activation.schema.json"
}
