{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ABBA Engine Team",
  "type": "object",
  "required": ["teamId", "name", "productId", "leagueLevel", "members", "swarmCoverage", "fallbacks", "declaredBudget", "status"],
  "properties": {
    "teamId": {"type": "string"},
    "name": {"type": "string"},
    "productId": {"type": "string"},
    "leagueLevel": {"enum": ["academy", "challenger", "premier", "champion", "reserve"]},
    "status": {"enum": ["forming", "ready", "competing", "qualified", "degraded", "retired"]},
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["providerId", "fractionId", "role", "swarms"],
        "properties": {
          "providerId": {"type": "string"},
          "fractionId": {"type": "string"},
          "role": {"type": "string"},
          "swarms": {"type": "array", "items": {"type": "string"}},
          "humanRole": {"type": ["string", "null"]},
          "aiRole": {"type": ["string", "null"]},
          "sealLevel": {"type": "integer", "minimum": 0, "maximum": 4}
        }
      }
    },
    "swarmCoverage": {"type": "array", "items": {"type": "string"}},
    "fallbacks": {"type": "array", "items": {"type": "object"}},
    "declaredBudget": {"type": "number", "minimum": 0},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}}
  }
}
